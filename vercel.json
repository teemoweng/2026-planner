{
  "cleanUrls": true,
  "rewrites": [
    { "source": "/", "destination": "/Planner" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options",   "value": "nosniff" },
        { "key": "Referrer-Policy",          "value": "strict-origin-when-cross-origin" }
      ]
    }
  ],
  "crons": [
    { "path": "/api/heartbeat", "schedule": "0 12 * * *" }
  ]
}
