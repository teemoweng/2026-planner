# ─── Supabase ────────────────────────────────────────────────
# From Supabase Dashboard → Project Settings
#   • SUPABASE_URL            → General → Project URL
#   • SUPABASE_ANON_KEY       → API Keys (Legacy) → anon  (public, used by frontend)
#   • SUPABASE_SERVICE_KEY    → API Keys (Legacy) → service_role  (secret, backend only)
# User access tokens are verified via JWKS (no shared secret needed).
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOi...
SUPABASE_SERVICE_KEY=eyJhbGciOi...

# ─── LLM provider ────────────────────────────────────────────
LLM_PROVIDER=openai                            # openai | anthropic
LLM_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
LLM_MODEL=doubao-seed-1-6-250615
LLM_API_KEY=ark-...
LLM_MAX_TOKENS=1024

# ─── Quota ───────────────────────────────────────────────────
FREE_TIER_DAILY_AI_CALLS=50                    # per user, last 24h

# ─── Runtime ─────────────────────────────────────────────────
PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:8000
